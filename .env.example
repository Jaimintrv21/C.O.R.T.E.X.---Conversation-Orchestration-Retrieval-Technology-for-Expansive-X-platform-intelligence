# ── C.O.R.T.E.X. Configuration ──────────────────────────────────────────────
# Copy to .env and customize for your deployment.

# App
C.O.R.T.E.X._ENVIRONMENT=development
C.O.R.T.E.X._DEBUG=true
C.O.R.T.E.X._SECRET_KEY=change-me-to-a-random-64-char-string
C.O.R.T.E.X._ALLOWED_ORIGINS=["http://localhost:3000"]
C.O.R.T.E.X._DATABASE_BACKEND=firebase

# Firebase / Firestore
C.O.R.T.E.X._FIREBASE_PROJECT_ID=
C.O.R.T.E.X._FIREBASE_STORAGE_BUCKET=
C.O.R.T.E.X._FIREBASE_SERVICE_ACCOUNT_PATH=
C.O.R.T.E.X._FIREBASE_SERVICE_ACCOUNT_JSON=

# Database (PostgreSQL 16 + pgvector)
C.O.R.T.E.X._DATABASE_URL=postgresql+asyncpg://cortex:cortex@localhost:5432/cortex
C.O.R.T.E.X._DATABASE_POOL_SIZE=20

# Redis
C.O.R.T.E.X._REDIS_URL=redis://localhost:6379/0
C.O.R.T.E.X._CELERY_BROKER_URL=redis://localhost:6379/1
C.O.R.T.E.X._CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT lifetime (enforced by Auth0 access tokens and refresh tokens)
C.O.R.T.E.X._JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
C.O.R.T.E.X._JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth0
C.O.R.T.E.X._AUTH0_DOMAIN=
C.O.R.T.E.X._AUTH0_AUDIENCE=
C.O.R.T.E.X._AUTH0_CLIENT_ID=
C.O.R.T.E.X._AUTH0_CLIENT_SECRET=
C.O.R.T.E.X._AUTH0_DATABASE_CONNECTION=Username-Password-Authentication
C.O.R.T.E.X._AUTH0_JWKS_CACHE_TTL_SECONDS=86400
C.O.R.T.E.X._EXTENSION_TOKEN_SECRET=change-me-extension-token-secret
C.O.R.T.E.X._EXTENSION_TOKEN_AUDIENCE=cortex-extension-ingest
C.O.R.T.E.X._EXTENSION_TOKEN_TTL_DAYS=30

# Encryption
C.O.R.T.E.X._MASTER_ENCRYPTION_KEY=change-me-32-byte-key-in-prod!!

# Meilisearch
C.O.R.T.E.X._MEILISEARCH_URL=http://localhost:7700
C.O.R.T.E.X._MEILISEARCH_API_KEY=cortex-meili-key

# MinIO (S3-compatible)
C.O.R.T.E.X._MINIO_ENDPOINT=localhost:9000
C.O.R.T.E.X._MINIO_ACCESS_KEY=cortex
C.O.R.T.E.X._MINIO_SECRET_KEY=cortex-secret
C.O.R.T.E.X._MINIO_BUCKET=cortex-uploads

# Ollama (local AI)
C.O.R.T.E.X._OLLAMA_BASE_URL=http://localhost:11434
C.O.R.T.E.X._OLLAMA_MODEL=llama3.2

# AI Routing
C.O.R.T.E.X._AI_LOCAL_ONLY=true
C.O.R.T.E.X._LITELLM_API_BASE=
C.O.R.T.E.X._LITELLM_API_KEY=
C.O.R.T.E.X._LLM_SUMMARIZATION_MODEL=ollama/llama3.2:3b
C.O.R.T.E.X._LLM_TOPIC_EXTRACTION_MODEL=ollama/mistral:7b
C.O.R.T.E.X._LLM_ARTIFACT_GENERATION_MODEL=ollama/llama3.1:8b
C.O.R.T.E.X._LLM_KNOWLEDGE_GRAPH_MODEL=ollama/qwen2.5:7b
C.O.R.T.E.X._LLM_FALLBACK_MODEL=openai/gpt-4o-mini

# Embeddings
C.O.R.T.E.X._EMBEDDING_MODEL=all-MiniLM-L6-v2
C.O.R.T.E.X._EMBEDDING_HIGH_QUALITY_MODEL=nomic-ai/nomic-embed-text-v1.5
C.O.R.T.E.X._EMBEDDING_CLOUD_MODEL=openai/text-embedding-3-small
C.O.R.T.E.X._EMBEDDING_DIMENSIONS=384
C.O.R.T.E.X._EMBEDDING_HIGH_QUALITY_DIMENSIONS=768
C.O.R.T.E.X._EMBEDDING_BATCH_SIZE=64
C.O.R.T.E.X._EMBEDDING_CHUNK_SIZE_TOKENS=512
C.O.R.T.E.X._EMBEDDING_CHUNK_OVERLAP_TOKENS=64
C.O.R.T.E.X._EMBEDDING_QUEUE_MAX_SIZE=1024

# Rate Limiting
C.O.R.T.E.X._RATE_LIMIT_AUTHENTICATED=100
C.O.R.T.E.X._RATE_LIMIT_UNAUTHENTICATED=10
C.O.R.T.E.X._RATE_LIMIT_EXTENSION=30

# Upload
C.O.R.T.E.X._MAX_UPLOAD_SIZE_MB=500

# Artifacts
C.O.R.T.E.X._ARTIFACT_STORAGE_PREFIX=artifacts

# Compose / Infra
POSTGRES_DB=cortex
POSTGRES_USER=cortex
POSTGRES_PASSWORD=change-me
MEILI_MASTER_KEY=change-me
MINIO_ROOT_USER=cortex
MINIO_ROOT_PASSWORD=change-me
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001
CADDY_DOMAIN=localhost
CADDY_EMAIL=admin@example.com
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

